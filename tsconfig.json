{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2018",
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "strictNullChecks": true,
    "strict": true,
    "lib": [
      "ES2018",
      "DOM"
    ]
  },
  "include": [
    "src/**/*.ts"
  ]
}
